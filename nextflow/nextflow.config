// Params for the offline spatial-omics recipe runner (wraps backend/cli.py).
params {
    input         = null                              // raw data folder, or .zarr/.zarr.zip in zarr mode
    recipe        = null                              // recipe JSON file, or a bundled recipe name
    parser        = null                              // reader key (io.xenium) / bare name (xenium) / 'zarr' / 'spatialdata'
    name          = null                              // base name for <name>.zarr.zip (default: derived from --input)
    reader_params = null                              // JSON object of extra reader kwargs (reader mode only)
    os_packages   = null                              // optional apt packages to install at runtime (e.g. 'libgl1 libglib2.0-0 libgomp1')
    outdir        = 'results'
    backend       = "${projectDir}/../backend"        // repo backend/ tree (cli.py + app/)
}

process {
    withName: RUN_ANALYSIS {
        cpus   = 4
        memory = 16.GB
    }
}

profiles {
    docker {
        // Public uv image (Debian bookworm-slim, Python 3.11). No custom build.
        process.container = 'ghcr.io/astral-sh/uv:python3.11-bookworm'
        docker.enabled    = true
    }

    // Quick end-to-end run over a bundled zarr + bundled recipe (compute + plot,
    // no OS image libs needed). Combine with docker: -profile test,docker
    test {
        params.parser = 'zarr'
        params.input  = "${projectDir}/../test-data/visium_hne.zarr"
        params.recipe = "${projectDir}/../backend/app/recipes/01_neighborhood_enrichment.json"
    }
}
