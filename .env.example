# AI / AWS Bedrock configuration (v3 Parts 6-8). Copy to .env (gitignored) and fill in.
# AI is strictly additive: with AI_ENABLED=false the chat panel is dark and the rest
# of the app runs normally.

# Turn the AI chat on.
AI_ENABLED=true

# Provider: "bedrock" for real AWS Bedrock, or "mock" for a credential-free demo of
# the agent loop / approval flow.
AI_PROVIDER=bedrock

# AWS Bedrock (only needed when AI_PROVIDER=bedrock).
AWS_REGION=us-east-1
# A Converse-capable model id or inference profile, e.g.:
#   anthropic.claude-3-5-sonnet-20241022-v2:0
#   us.anthropic.claude-3-5-sonnet-20241022-v2:0   (cross-region inference profile)
BEDROCK_MODEL_ID=

# Credentials — prefer your normal AWS credential chain (SSO/role/profile). These are
# only read if set; never commit real values.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional context-compaction tuning (v3 Part 7).
# SQV_CONTEXT_TOKEN_LIMIT=6000
# SQV_CONTEXT_KEEP_RECENT_N=8

# Cirro upload configuration. Strictly additive: dark (upload button hidden) unless
# all three are set. Service-account (OAuth client-credentials) identity — no
# interactive login.
CIRRO_BASE_URL=
CIRRO_CLIENT_ID=
CIRRO_CLIENT_SECRET=
